{
  "name": "service-dependency-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace @service-dependency/api",
    "dev:web": "npm run dev --workspace @service-dependency/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
